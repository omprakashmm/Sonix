# ========================
# Sonix — Backend Environment Variables
# ========================
# Copy to backend/.env and fill in your values

# ------- DATABASE -------
# Get from Supabase / Railway / Neon / any Postgres provider
DATABASE_URL="postgresql://user:password@host:5432/sonix_db?sslmode=require"

# ------- SERVER -------
NODE_ENV="production"           # development | production
BACKEND_PORT=3001

# ------- JWT -------
JWT_SECRET="change-this-to-a-random-64-char-string-in-production"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_SECRET="another-random-secret-for-refresh-tokens"

# ------- CORS -------
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS="https://your-frontend.vercel.app,http://localhost:3000"

# ------- STORAGE -------
STORAGE_TYPE="r2"               # "local" | "s3" | "r2"
LOCAL_UPLOAD_PATH="./uploads"
MAX_FILE_SIZE_MB=100

# ------- CLOUDFLARE R2 (only if STORAGE_TYPE=r2) -------
# Dashboard → https://dash.cloudflare.com → R2 → Manage API tokens
R2_ACCOUNT_ID=""                 # e.g. 3f49a4b21c8a3d9e...
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="sonix-media"          # your R2 bucket name
# Enable "Public Access" on the bucket OR add a custom domain in R2 settings
R2_PUBLIC_URL=""                 # e.g. https://pub-xxxx.r2.dev  OR  https://cdn.yourdomain.com

# ------- AWS S3 (only if STORAGE_TYPE=s3) -------
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""
AWS_S3_CDN_URL=""

# ------- AUDIO TOOLS -------
FFMPEG_PATH=""                  # Leave empty if ffmpeg is in PATH
YTDLP_PATH=""                   # Leave empty if yt-dlp is in PATH
AUDIO_QUALITY="320"             # kbps: 128 | 192 | 256 | 320
AUDIO_FORMAT="mp3"

# ------- RATE LIMITING -------
RATE_LIMIT_WINDOW_MS=900000     # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
YOUTUBE_IMPORT_RATE_LIMIT=10    # per 15-min window

# ------- REDIS (optional — for job queue) -------
REDIS_URL=""                    # e.g. redis://default:password@host:6379
